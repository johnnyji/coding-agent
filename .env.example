# GitHub App (bot account — used by api service to open PRs)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# GitHub OAuth (used by web service for NextAuth sign-in)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth (web service)
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Database (orchestrator)
DATABASE_URL=
REDIS_URL=

# Claude
ANTHROPIC_API_KEY=

# API URL (set in web service so the browser knows where to call the api service)
NEXT_PUBLIC_API_URL=

# Sandbox
SANDBOX_BASE_PATH=/app/sandboxes
SANDBOX_MIRROR_PATH=/app/mirrors
SANDBOX_PORT_RANGE_START=5100
SANDBOX_PORT_RANGE_END=5199

# App-specific (Distru sandbox)
# These are injected into config/env/dev.env and config/env/test.env at sandbox creation time.
# Engineers normally set these manually on their local machines; here they live as Railway env vars.
DISTRU_SECRET_KEY_BASE=
DISTRU_AWS_ACCESS_KEY_ID=
DISTRU_AWS_SECRET_ACCESS_KEY=
DISTRU_ANTHROPIC_API_KEY=
DISTRU_OPENAI_API_KEY=
DISTRU_COHERE_API_KEY=
DISTRU_GOOGLE_GEMINI_API_KEY=
DISTRU_CHARGEBEE_API_KEY=
DISTRU_GOOGLE_MAPS_API_KEY=
